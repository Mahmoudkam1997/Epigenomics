# Step 2: Sort BAM
echo "   2. Sorting BAM..."
samtools sort results/alignments/SRR891268.bam -o results/alignments/SRR891268.sorted.bam

# Step 3: Index sorted BAM
echo "   3. Indexing sorted BAM..."
samtools index results/alignments/SRR891268.sorted.bam

# Step 4: Remove mitochondrial reads
echo "   4. Removing mitochondrial reads..."
samtools idxstats results/alignments/SRR891268.sorted.bam | cut -f1 | grep -v chrM | \
    xargs samtools view -b results/alignments/SRR891268.sorted.bam > results/alignments/SRR891268.noM.bam
samtools index results/alignments/SRR891268.noM.bam

# Step 5: Remove duplicates with Picard (MORE RELIABLE!)
