# Load libraries
library(ggplot2)
library(dplyr)

# -------------------------------
# 1. READ PEAKS FILE
# -------------------------------
peaks <- read.table("SRR891268_chr22_peaks.broadPeak", 
                    header = FALSE, 
                    sep = "\t",
                    col.names = c("chr", "start", "end", "name", "score",
                                  "strand", "fold_enrichment", "neg_log10_q", "summit"))

# -------------------------------
# 2. READ GENES FILE (AUTO-DETECTS COLUMNS)
# -------------------------------
# Read raw file
genes_raw <- read.table("peaks_genes.txt", header = FALSE, sep = "\t", fill = TRUE)

# Take only first 8 columns (peak info + gene info)
genes <- genes_raw[, 1:8]

# Assign column names
colnames(genes) <- c("peak_chr", "peak_start", "peak_end", "peak_name",
                     "gene_chr", "gene_start", "gene_end", "gene_name")

# -------------------------------
# 3. MERGE PEAKS WITH GENES
# -------------------------------
peaks_with_genes <- cbind(peaks, gene_name = genes$gene_name)

# Check it worked
head(peaks_with_genes)

#############################################################################

# Count how many peaks are near each gene
gene_counts <- table(genes$gene_name)
top_genes <- head(sort(gene_counts, decreasing = TRUE), 15)

# Create data frame for plotting
top_genes_df <- data.frame(
  Gene = names(top_genes),
  Count = as.numeric(top_genes)
)

# Plot
ggplot(top_genes_df, aes(x = reorder(Gene, Count), y = Count)) +
  geom_bar(stat = "identity", fill = "steelblue") +
  coord_flip() +
  labs(title = "Top 15 Genes Near Open Chromatin Peaks (chr22)",
       x = "Gene Name",
       y = "Number of Peaks") +
  theme_minimal() +
  theme(
    axis.text.y = element_text(size = 10),
    plot.title = element_text(hjust = 0.5, face = "bold")
  )

