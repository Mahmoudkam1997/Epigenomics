#!/bin/bash

# Define where Trimmomatic is
TRIMMOMATIC_JAR="trimmomatic-0.39.jar"   # Use this if .jar is in current directory
# OR
# TRIMMOMATIC_JAR="./trimmomatic-0.39.jar"  # Use this if you want ./ before it
# OR
# TRIMMOMATIC_JAR="Trimmomatic-0.39/trimmomatic-0.39.jar"  # Use this if it's in the folder

# Adapter file (Nextera for ATAC-seq or Nextera-based libraries)
ADAPTERS="./NexteraPE-PE.fa"

# Output folder
mkdir -p trimmed_output

# Loop through R1 files and process matching R2 files
for R1 in *_R1.fastq; do
    # Skip if no files found
    [ -e "$R1" ] || continue
    
    # Determine R2 file by replacing _R1 with _R2
    R2="${R1/_R1/_R2}"
    
    # Check if R2 exists
    if [ ! -f "$R2" ]; then
        echo "??  Warning: No matching R2 file for $R1 — skipping"
        continue
    fi
    
    # Get base name (remove _R1.fastq)
    BASENAME=$(basename "$R1" _R1.fastq)
    
    # Output files
    R1_PAIRED="trimmed_output/${BASENAME}_R1_paired.fastq"
    R1_UNPAIRED="trimmed_output/${BASENAME}_R1_unpaired.fastq"
    R2_PAIRED="trimmed_output/${BASENAME}_R2_paired.fastq"
    R2_UNPAIRED="trimmed_output/${BASENAME}_R2_unpaired.fastq"
    
    echo "?? Processing $BASENAME..."
    echo "   R1: $R1"
    echo "   R2: $R2"
    
    java -jar "$TRIMMOMATIC_JAR" PE -phred33 \
        "$R1" "$R2" \
        "$R1_PAIRED" "$R1_UNPAIRED" \
        "$R2_PAIRED" "$R2_UNPAIRED" \
        ILLUMINACLIP:"$ADAPTERS":2:30:10 \
        LEADING:3 \
        TRAILING:3 \
        SLIDINGWINDOW:4:20 \
        MINLEN:50
    
    echo "? Finished $BASENAME"
done

echo "?? All paired-end reads trimmed successfully!"
#!/bin/bash

# Create the index directory if it doesn't exist
mkdir -p genome/index

# Check if the genome file exists
if [ ! -f "genome/chr22.fa" ]; then
    echo "? Error: genome/chr22.fa not found!"
    echo "   Please make sure the genome file is in the genome/ folder."
    exit 1
fi

# Check if index already exists
if [ -f "genome/index/chr22.1.bt2" ]; then
    echo "??  Index already exists. Removing old index..."
    rm -f genome/index/chr22*.bt2
fi

echo "?? Building Bowtie2 index for chr22..."
echo "   Genome file: genome/chr22.fa"
echo "   Index output: genome/index/chr22"

# Build the index
bowtie2-build genome/chr22.fa genome/index/chr22

# Check if index was created successfully
if [ -f "genome/index/chr22.1.bt2" ]; then
    echo ""
    echo "? Index built successfully!"
    echo "   Index files created:"
    ls -lh genome/index/chr22*.bt2
else
    echo ""
    echo "? Index building failed!"
    exit 1
fi
#!/bin/bash

# Create output directory for alignments
mkdir -p results/alignments

# Check if Bowtie2 index exists
if [ ! -f "genome/index/chr22.1.bt2" ]; then
    echo "? Error: Bowtie2 index not found!"
    echo "   Please run ./build_index.sh first."
    exit 1
fi

# Check if trimmed reads exist
if [ -z "$(ls -1 trimmed_output/*_R1_paired.fastq 2>/dev/null)" ]; then
    echo "? Error: No trimmed paired-end reads found!"
    echo "   Expected: trimmed_output/*_R1_paired.fastq"
    echo "   Please run trimming first."
    exit 1
fi

echo "?? Aligning all samples..."

# Loop through all R1 paired files
for R1 in trimmed_output/*_R1_paired.fastq; do
    # Skip if no files found
    [ -e "$R1" ] || continue
    
    # Determine R2 file by replacing _R1 with _R2
    R2="${R1/_R1/_R2}"
    
    # Check if R2 exists
    if [ ! -f "$R2" ]; then
        echo "??  Warning: No matching R2 file for $R1 — skipping"
        continue
    fi
    
    # Get base name (remove _R1_paired.fastq)
    BASENAME=$(basename "$R1" _R1_paired.fastq)
    
    echo ""
    echo "?? Aligning $BASENAME..."
    echo "   R1: $R1"
    echo "   R2: $R2"
    echo "   Output: results/alignments/${BASENAME}.sam"
    
    # Run Bowtie2 alignment
    bowtie2 -x genome/index/chr22 \
            -1 "$R1" \
            -2 "$R2" \
            -S "results/alignments/${BASENAME}.sam" \
            --threads 4 2>&1 | tee "results/alignments/${BASENAME}.alignment.log"
    
    # Check if alignment succeeded
    if [ -f "results/alignments/${BASENAME}.sam" ]; then
        # Count alignments
        ALIGN_COUNT=$(grep -v "^@" "results/alignments/${BASENAME}.sam" | wc -l)
        echo "   ? Alignment complete for $BASENAME"
        echo "   Alignment lines: $ALIGN_COUNT"
        
        # Show alignment summary from log
        echo "   ?? Alignment summary:"
        tail -5 "results/alignments/${BASENAME}.alignment.log" | sed 's/^/   /'
    else
        echo "   ? Alignment failed for $BASENAME!"
        exit 1
    fi
done

echo ""
echo "?? All samples aligned successfully!"
echo "   SAM files: results/alignments/*.sam"
echo "   Log files: results/alignments/*.alignment.log"

fi
